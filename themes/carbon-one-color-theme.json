{
    //
    /* METADATA ||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "name": "Carbon One",
    "type": "light",
    "semanticHighlighting": false,
    "semanticTokenColors": {},

    /* ENVIRONMENT |||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "colors": {
        //

        /* REAL RASCAL ------------------------------------------------------ */

        // Gray 90 (Border)
        "editorGroupHeader.tabsBorder": "#21272A",
        "input.border": "#21272A",
        "notificationToast.border": "#21272A",
        "panel.border": "#21272A",
        "sideBar.border": "#21272A",
        "tab.border": "#21272A",
        "titleBar.border": "#21272A",

        // Gray 10 (Makeup: Default Editor Background Color)
        "tab.activeBackground": "#F4F4F4",
        "tab.activeBorder": "#F4F4F4",

        // Green 50 + Warm Burnout
        "button.background": "#24a148",
        "button.hoverBackground": "#a04828",

        // Yellow 10 Hover
        "editor.lineHighlightBackground": "#f8e6a0",

        /* WINDOWS 12 ------------------------------------------------------- */

        "activityBar.activeBackground": "#969FE0",
        "activityBar.background": "#B5BBE7",
        "activityBar.foreground": "#262734",
        "activityBar.inactiveForeground": "#262734",
        "sideBar.background": "#E4E4F2",
        "sideBar.foreground": "#000000",
        "statusBar.background": "#7378D6",

        // WARM BURNOUT
        "activityBar.border": "#B5BBE7",
        "editorGroupHeader.tabsBackground": "#EDE6DA",
        "focusBorder": "#EDE6DA",
        "inputOption.activeForeground": "#B8522E",
        "input.background": "#EDE6DA",
        "panel.background": "#EDE6DA",
        "panelTitle.activeBorder": "#B8522E",
        "statusBar.border": "#7378D6",
        "titleBar.activeBackground": "#EDE6DA",

        /* CAMPBELL POWERSHELL ---------------------------------------------- */

        "terminal.ansiBlack": "#0C0C0C",
        "terminal.ansiBlue": "#0037DA",
        "terminal.ansiBrightBlack": "#767676",
        "terminal.ansiBrightBlue": "#3B78FF",
        "terminal.ansiBrightCyan": "#61D6D6",
        "terminal.ansiBrightGreen": "#16C60C",
        "terminal.ansiBrightMagenta": "#B4009E",
        "terminal.ansiBrightRed": "#E74856",
        "terminal.ansiBrightWhite": "#F2F2F2",
        "terminal.ansiBrightYellow": "#F9F1A5",
        "terminal.ansiCyan": "#3A96DD",
        "terminal.ansiGreen": "#13A10E",
        "terminal.ansiMagenta": "#881798",
        "terminal.ansiRed": "#C50F1F",
        "terminal.ansiWhite": "#CCCCCC",
        "terminal.ansiYellow": "#C19C00",

        // Main Terminal Colors
        "terminal.background": "#012456",
        "terminal.foreground": "#CCCCCC",
        "terminalCursor.foreground": "#FFFFFF",
        "terminal.selectionBackground": "#FFFFFF50",

        /* IBM CARBON (Gray 10 Schema) -------------------------------------- */

        "editor.background": "#F4F4F4",
        "editor.foreground": "#161616"
    },

    /* SYNTAX ||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "tokenColors": [
        /* ==================================================================
           BASE / ESTRUCTURA (Gray 100 - #161616)
           Operadores, puntuación y elementos neutros de sintaxis
           ================================================================== */
        {
            "scope": ["keyword.operator", "meta.brace", "punctuation"],
            "settings": { "foreground": "#161616" }
        },

        /* ==================================================================
           TIPOS / CLASES (Yellow 60 - #8e6a00)
           Nombres de tipos, clases, interfaces y estructuras de datos
           ================================================================== */
        {
            "scope": [
                "entity.name.class",
                "entity.name.type",
                "entity.name.type.class",
                "entity.other.inherited-class",
                "support.class"
            ],
            "settings": { "foreground": "#8e6a00" }
        },

        /* Yellow Hover 60 -------------------------------------------------- */

        {
            "scope": [
                "entity.name.type.interface",
                "entity.name.type.alias",
                "meta.type.parameters",
                "support.type"
            ],
            "settings": {
                "foreground": "#755800"
            }
        },

        /* ==================================================================
           CONSTANTES / ATRIBUTOS (Orange 60 - #ba4e00)
           Valores literales, atributos y variables de solo lectura
           ================================================================== */
        {
            "scope": [
                "constant",
                "constant.numeric",
                "constant.variable",
                "entity.other.attribute-name",
                "keyword.other.unit",
                "markup.bold",
                "markup.inline",
                "markup.quote",
                "support.constant",
                "token.warn-token",
                "variable.other.constant"
            ],
            "settings": { "foreground": "#ba4e00" }
        },

        /* ==================================================================
           VARIABLES / ETIQUETAS / PROPIEDADES (Red 60 - #da1e28)
           Elementos identificadores, tags y referencias
           ================================================================== */
        {
            "scope": [
                "entity.name.tag",
                "markup.deleted",
                "markup.heading",
                "meta.definition.variable",
                "string.other.link",
                "support.type.property-name",
                "support.type.vendored.property-name",
                "support.variable",
                "support.variable.property",
                "variable",
                "variable.other.readwrite.alias"
            ],
            "settings": { "foreground": "#da1e28" }
        },

        /* ==================================================================
           ESTADO / DEPURACIÓN (Magenta 60 - #d02670)
           Tokens de error, debug e interpolación
           ================================================================== */
        {
            "scope": [
                "invalid",
                "support.other.parenthesis.regexp",
                "token.debug-token",
                "token.error-token",
                "variable.interpolation"
            ],
            "settings": { "foreground": "#d02670" }
        },

        /* Magenta Hover 60 ------------------------------------------------- */

        {
            "scope": ["constant.regexp"],
            "settings": {
                "foreground": "#b0215f"
            }
        },

        /* ==================================================================
           PALABRAS CLAVE / CONTROL (Purple 60 - #8a3ffc)
           Keywords, storage y modificadores de flujo
           ================================================================== */
        {
            "scope": [
                "entity.name.namespace",
                "entity.other.attribute",
                "keyword",
                "markup.changed",
                "markup.italic",
                "storage"
            ],
            "settings": { "foreground": "#8a3ffc" }
        },

        /* ==================================================================
           FUNCIONES / MÉTODOS (Blue 60 - #0f62fe)
           Nombres de funciones, métodos y elementos ejecutables
           ================================================================== */
        {
            "scope": [
                "constant.character",
                "constant.language",
                "entity.name.function",
                "entity.name.section",
                "keyword.other.special-method",
                "storage.modifier",
                "support.function.any-method",
                "token.info-token",
                "variable.language"
            ],
            "settings": { "foreground": "#0f62fe" }
        },

        /* Blue Hover 60 ---------------------------------------------------- */

        {
            "scope": ["string.template", "meta.template.expression"],
            "settings": {
                "foreground": "#0050e6"
            }
        },

        /* ==================================================================
           ESCAPES / REGEX / TIPOS SOPORTE (Cyan 60 - #0072c3)
           Caracteres de escape, expresiones regulares y tipos genéricos
           ================================================================== */
        {
            "scope": [
                "constant.character.escape",
                "constant.other.symbol",
                "markup.link",
                "string.regexp"
            ],
            "settings": { "foreground": "#0072c3" }
        },

        /* Cyan Hover 60 ---------------------------------------------------- */

        {
            "scope": ["meta.object-literal.key", "variable.other.enummember"],
            "settings": {
                "foreground": "#005fa3"
            }
        },

        /* ==================================================================
           FUNCIONES DE SOPORTE (Teal 60 - #007d79)
           Utilidades y funciones del runtime/lenguaje base
           ================================================================== */
        {
            "scope": ["meta.preprocessor.numeric"],
            "settings": { "foreground": "#007d79" }
        },

        /* ==================================================================
           STRINGS / MARKUP INSERTADO (Green 60 - #198038)
           Cadenas de texto y contenido insertado en diffs
           ================================================================== */
        {
            "scope": ["string", "markup.inserted", "markup.raw"],
            "settings": { "foreground": "#198038" }
        },

        /* ==================================================================
           COMENTARIOS (Gray 60 - #6f6f6f)
           Texto no ejecutable, con énfasis visual suave
           ================================================================== */
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": {
                "foreground": "#6f6f6f",
                "fontStyle": "italic"
            }
        }
    ]
}
