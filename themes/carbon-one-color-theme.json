{
    //
    /* METADATA ||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "name": "Carbon One",
    "type": "light",
    "semanticHighlighting": false,
    "semanticTokenColors": {},

    /* ENVIRONMENT |||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "colors": {
        //

        /* REAL RASCAL ------------------------------------------------------ */

        // Gray 90 (Border)
        "editorGroupHeader.tabsBorder": "#21272A",
        "input.border": "#21272A",
        "notificationToast.border": "#21272A",
        "panel.border": "#21272A",
        "sideBar.border": "#21272A",
        "tab.border": "#21272A",
        "titleBar.border": "#21272A",

        // Gray 10 (Makeup: Default Editor Background Color)
        "tab.activeBackground": "#F4F4F4",
        "tab.activeBorder": "#F4F4F4",

        // Green 50 + Warm Burnout
        "button.background": "#24a148",
        "button.hoverBackground": "#a04828",

        // Yellow 10 Hover
        "editor.lineHighlightBackground": "#f8e6a0",

        /* WINDOWS 12 ------------------------------------------------------- */

        "activityBar.activeBackground": "#969FE0",
        "activityBar.background": "#B5BBE7",
        "activityBar.foreground": "#262734",
        "activityBar.inactiveForeground": "#262734",
        "sideBar.background": "#E4E4F2",
        "sideBar.foreground": "#000000",
        "statusBar.background": "#7378D6",

        // WARM BURNOUT
        "activityBar.border": "#B5BBE7",
        "editorGroupHeader.tabsBackground": "#EDE6DA",
        "focusBorder": "#EDE6DA",
        "inputOption.activeForeground": "#B8522E",
        "input.background": "#EDE6DA",
        "panel.background": "#EDE6DA",
        "panelTitle.activeBorder": "#B8522E",
        "statusBar.border": "#7378D6",
        "titleBar.activeBackground": "#EDE6DA",

        /* CAMPBELL POWERSHELL ---------------------------------------------- */

        "terminal.ansiBlack": "#0C0C0C",
        "terminal.ansiBlue": "#0037DA",
        "terminal.ansiBrightBlack": "#767676",
        "terminal.ansiBrightBlue": "#3B78FF",
        "terminal.ansiBrightCyan": "#61D6D6",
        "terminal.ansiBrightGreen": "#16C60C",
        "terminal.ansiBrightMagenta": "#B4009E",
        "terminal.ansiBrightRed": "#E74856",
        "terminal.ansiBrightWhite": "#F2F2F2",
        "terminal.ansiBrightYellow": "#F9F1A5",
        "terminal.ansiCyan": "#3A96DD",
        "terminal.ansiGreen": "#13A10E",
        "terminal.ansiMagenta": "#881798",
        "terminal.ansiRed": "#C50F1F",
        "terminal.ansiWhite": "#CCCCCC",
        "terminal.ansiYellow": "#C19C00",

        // Main Terminal Colors
        "terminal.background": "#012456",
        "terminal.foreground": "#CCCCCC",
        "terminalCursor.foreground": "#FFFFFF",
        "terminal.selectionBackground": "#FFFFFF50",

        /* IBM CARBON (Gray 10 Schema) -------------------------------------- */

        "editor.background": "#F4F4F4",
        "editor.foreground": "#161616"
    },

    /* SYNTAX ||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "tokenColors": [
        //
        // Gray 100 ============================================================
        {
            "scope": [
                "punctuation",
                "variable.object",
                "variable.other.readwrite",
                //
                // Markdown Subsystem
                "markup.list"
            ],
            "settings": { "foreground": "#161616" }
        },

        // Yellow 60 ===========================================================
        {
            "scope": [
                "entity.name.class",
                "entity.other.inherited-class",
                "support.class",
                //
                // Markdown Subsystem
                "markup.bold"
            ],
            "settings": { "foreground": "#8e6a00", "fontStyle": "bold" }
        },

        // Orange 60 ===========================================================
        {
            "scope": [
                "constant",
                "constant.numeric",
                "constant.variable",
                "entity.name.type",
                "entity.other.attribute-name",
                "support.constant",
                "token.warn-token",
                "variable.other.constant",
                //
                // Markdown Subsystem
                "markup.inline"
            ],
            "settings": { "foreground": "#ba4e00" }
        },

        // Red 60 ==============================================================
        {
            "scope": [
                "entity.name.tag",
                "support.variable",
                //
                // Markdown Subsystem
                "markup.deleted",
                "markup.heading"
            ],
            "settings": { "foreground": "#da1e28" }
        },

        // Magenta 60 ==========================================================
        {
            "scope": [
                "constant.regexp",
                "invalid",
                "support.other",
                "token.debug-token",
                "token.error-token"
                //
                // Markdown Subsystem
            ],
            "settings": { "foreground": "#d02670" }
        },

        // Purple 60 ===========================================================
        {
            "scope": [
                "entity.name.namespace",
                "entity.other.attribute",
                "keyword",
                "storage",
                //
                // Markdown Subsystem
                "markup.italic"
            ],
            "settings": { "foreground": "#8a3ffc", "fontStyle": "italic" }
        },

        // Blue 60 =============================================================
        {
            "scope": [
                "constant.character",
                "constant.language",
                "entity.name.function",
                "support.function",
                "support.type", // <<<<<<<<<<<<<<<<<<<<<<<  Moved from Yellow 60
                "token.info-token",
                //
                // Markdown Subsystem
                "markup.table",
                "markup.quote",
                "markup.underline"
            ],
            "settings": { "foreground": "#0f62fe" }
        },

        // Cyan 60 =============================================================
        {
            "scope": [
                "constant.other"
                //
                // Markdown Subsystem
            ],
            "settings": { "foreground": "#0072c3" }
        },

        // Teal 60 =============================================================
        {
            "scope": [
                //
                // Markdown Subsystem
                "markup.fenced_code"
            ],
            "settings": { "foreground": "#007d79" }
        },

        // Green 60 ============================================================
        {
            "scope": [
                "string",
                //
                // Markdown Subsystem
                "markup.inserted",
                "markup.raw"
            ],
            "settings": { "foreground": "#198038" }
        },

        // Gray 60 =============================================================
        {
            "scope": [
                "comment",
                //
                // Markdown Subsystem
                "markup.strikethrough"
            ],
            "settings": {
                "foreground": "#6f6f6f",
                "fontStyle": "italic"
            }
        }
    ]
}
