{
    //
    /* METADATA ||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "name": "Carbon One",
    "type": "light",
    "semanticHighlighting": false,
    "semanticTokenColors": {},

    /* ENVIRONMENT |||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "colors": {
        //

        /* REAL RASCAL ------------------------------------------------------ */

        // Gray 90 (Border)
        "editorGroupHeader.tabsBorder": "#21272A",
        "input.border": "#21272A",
        "notificationToast.border": "#21272A",
        "panel.border": "#21272A",
        "sideBar.border": "#21272A",
        "tab.border": "#21272A",
        "titleBar.border": "#21272A",

        // Gray 10 (Makeup: Default Editor Background Color)
        "tab.activeBackground": "#F4F4F4",
        "tab.activeBorder": "#F4F4F4",

        // Green 50 + Warm Burnout
        "button.background": "#24a148",
        "button.hoverBackground": "#a04828",

        // Yellow 10
        "editor.lineHighlightBackground": "#fcf4d6",

        /* WINDOWS 12 ------------------------------------------------------- */

        "activityBar.activeBackground": "#969FE0",
        "activityBar.background": "#B5BBE7",
        "activityBar.foreground": "#262734",
        "activityBar.inactiveForeground": "#262734",
        "sideBar.background": "#E4E4F2",
        "sideBar.foreground": "#000000",
        "statusBar.background": "#7378D6",

        // WARM BURNOUT
        "activityBar.border": "#B5BBE7",
        "editorGroupHeader.tabsBackground": "#EDE6DA",
        "focusBorder": "#EDE6DA",
        "inputOption.activeForeground": "#B8522E",
        "input.background": "#EDE6DA",
        "panel.background": "#EDE6DA",
        "panelTitle.activeBorder": "#B8522E",
        "statusBar.border": "#7378D6",
        "titleBar.activeBackground": "#EDE6DA",

        /* CAMPBELL POWERSHELL ---------------------------------------------- */

        "terminal.ansiBlack": "#0C0C0C",
        "terminal.ansiBlue": "#0037DA",
        "terminal.ansiBrightBlack": "#767676",
        "terminal.ansiBrightBlue": "#3B78FF",
        "terminal.ansiBrightCyan": "#61D6D6",
        "terminal.ansiBrightGreen": "#16C60C",
        "terminal.ansiBrightMagenta": "#B4009E",
        "terminal.ansiBrightRed": "#E74856",
        "terminal.ansiBrightWhite": "#F2F2F2",
        "terminal.ansiBrightYellow": "#F9F1A5",
        "terminal.ansiCyan": "#3A96DD",
        "terminal.ansiGreen": "#13A10E",
        "terminal.ansiMagenta": "#881798",
        "terminal.ansiRed": "#C50F1F",
        "terminal.ansiWhite": "#CCCCCC",
        "terminal.ansiYellow": "#C19C00",

        // Main Terminal Colors
        "terminal.background": "#012456",
        "terminal.foreground": "#CCCCCC",
        "terminalCursor.foreground": "#FFFFFF",
        "terminal.selectionBackground": "#FFFFFF50",

        /* IBM CARBON (Gray 10 Schema) -------------------------------------- */

        "editor.background": "#F4F4F4",
        "editor.foreground": "#161616"
    },

    /* SYNTAX ||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "tokenColors": [
        //
        // Gray 100 =========================================================(0)
        {
            "scope": [
                "punctuation",
                "variable.other.readwrite",
                "variable.parameter"
            ],
            "settings": { "foreground": "#161616" }
        },
        {
            "scope": ["ATOM.ONE.LIGHT"],
            "settings": { "foreground": "#383A42" }
        },

        // Yellow 60 ========================================================(1)
        {
            "scope": [
                "constant",
                "entity.other.attribute-name",
                "markup.bold",
                "keyword.other.unit",
                "punctuation.definition.bold",
                "punctuation.definition.constant",
                "punctuation.definition.link",
                "support.constant",
                "variable.other.constant"
            ],
            "settings": { "foreground": "#8e6a00" }
        },
        {
            "scope": ["ATOM.ONE.LIGHT"],
            "settings": { "foreground": "#986801" }
        },

        // Orange 60 ========================================================(2)
        {
            "scope": [
                "entity.name.type",
                "entity.name.type.alias",
                "entity.name.type.interface",
                "entity.other.inherited-class",
                "support.class"
            ],
            "settings": { "foreground": "#ba4e00" }
        },
        {
            "scope": ["ATOM.ONE.LIGHT"],
            "settings": { "foreground": "#C18401" }
        },

        // Red 60 ===========================================================(3)
        {
            "scope": [
                "entity.name.section",
                "entity.name.tag",
                "keyword.other.definition",
                "markup.deleted",
                "punctuation.definition.heading",
                "source",
                "string.other.link.description",
                "support.type.property-name",
                "support.variable",
                "variable",
                "variable.language",
                "variable.other",
                "variable.other.readwrite.alias"
            ],
            "settings": { "foreground": "#da1e28" }
        },
        {
            "scope": ["ATOM.ONE.LIGHT"],
            "settings": { "foreground": "#E45649" }
        },

        // Magenta 60 =======================================================(4)
        {
            "scope": [
                "punctuation.definition",
                "punctuation.section.embedded",
                "variable.interpolation"
            ],
            "settings": { "foreground": "#d02670" }
        },
        {
            "scope": ["ATOM.ONE.LIGHT"],
            "settings": { "foreground": "#CA1243" }
        },

        // Purple 60 ========================================================(5)
        {
            "scope": [
                "keyword.control",
                "keyword.other",
                "storage.modifier",
                "keyword.operator.expression",
                "keyword.operator.new",
                "markup.italic",
                "markup.underline",
                "punctuation.definition.entity",
                "punctuation.definition.italic",
                "punctuation.definition.metadata",
                "punctuation.section",
                "storage.type"
            ],
            "settings": { "foreground": "#8a3ffc" }
        },
        {
            "scope": ["ATOM.ONE.LIGHT"],
            "settings": { "foreground": "#A626A4" }
        },

        // Blue 60 ==========================================================(6)
        {
            "scope": ["entity.name.function", "string.other.link.title"],
            "settings": { "foreground": "#0f62fe" }
        },
        {
            "scope": ["ATOM.ONE.LIGHT"],
            "settings": { "foreground": "#4078F2" }
        },

        // Cyan 60 ==========================================================(7)
        {
            "scope": [
                "constant.character",
                "constant.language",
                "constant.other",
                "keyword.operator",
                "storage.type.property",
                "string.regexp",
                "support.function",
                "support.type.builtin",
                "support.type.primitive"
            ],
            "settings": { "foreground": "#0072c3" }
        },
        {
            "scope": ["ATOM.ONE.LIGHT"],
            "settings": { "foreground": "#0184BC" }
        },

        // Teal 60 ==========================================================(8)
        {
            "scope": [
                "markup.changed",
                "markup.heading",
                "markup.inline",
                "markup.link",
                "markup.list",
                "markup.raw",
                "markup.table",
                "markup.untracked"
            ],
            "settings": { "foreground": "#007d79" }
        },
        {
            "scope": ["ATOM.ONE.LIGHT"],
            "settings": { "foreground": "#A0A1A7" }
        },

        // Green 60 =========================================================(9)
        {
            "scope": [
                "entity.name.type.module",
                "markup.inserted",
                "string.quoted",
                "string.unquoted",
                "string.template"
            ],
            "settings": { "foreground": "#198038" }
        },
        {
            "scope": ["ATOM.ONE.LIGHT"],
            "settings": { "foreground": "#50A14F" }
        },

        // Gray 60 =========================================================(10)
        {
            "scope": [
                "comment.block",
                "comment.line",
                "markup.quote",
                "punctuation.definition.comment",
                "punctuation.definition.quote"
            ],
            "settings": {
                "foreground": "#6f6f6f",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["ATOM.ONE.LIGHT"],
            "settings": { "foreground": "#696C77" }
        }
    ]
}
