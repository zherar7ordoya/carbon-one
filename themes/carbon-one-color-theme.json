{
    //
    /* METADATA ||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "name": "Carbon One",
    "type": "light",
    "semanticHighlighting": false,
    "semanticTokenColors": {},

    /* ENVIRONMENT |||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "colors": {
        //

        /* Real Rascal  ----------------------------------------------------- */

        "activityBar.border": "#21272A", // Gray 90
        "button.background": "#2DA44E",
        "editorGroup.border": "#21272A", // Gray 90
        "editorGroupHeader.tabsBorder": "#21272A", // Gray 90
        "input.background": "#EDE6DA",
        "input.border": "#21272A", // Gray 90
        "inputOption.activeForeground": "#B8522E",
        "panel.background": "#EDE6DA",
        "panel.border": "#21272A", // Gray 90
        "panelTitle.activeBorder": "#B8522E",
        "sideBar.border": "#21272A", // Gray 90
        "tab.activeBackground": "#F4F4F4",
        "tab.activeBorder": "#F4F4F4", // Gray 10
        "statusBar.border": "#21272A", // Gray 90
        "tab.border": "#21272A", // Gray 90
        "titleBar.border": "#21272A", // Gray 90

        /* Windows 12 ------------------------------------------------------- */

        "activityBar.activeBackground": "#969fe0",
        "activityBar.background": "#b5bbe7",
        "activityBar.foreground": "#262734",
        "activityBar.inactiveForeground": "#262734",
        "sideBar.background": "#fcf4d6", // Yellow 10
        "sideBar.foreground": "#21272A", // Gray 90
        "statusBar.background": "#7378d6",
        "titleBar.activeBackground": "#EDE6DA",

        /* Campbell PowerShell ---------------------------------------------- */

        "terminal.ansiBlack": "#0C0C0C",
        "terminal.ansiBlue": "#0037DA",
        "terminal.ansiBrightBlack": "#767676",
        "terminal.ansiBrightBlue": "#3B78FF",
        "terminal.ansiBrightCyan": "#61D6D6",
        "terminal.ansiBrightGreen": "#16C60C",
        "terminal.ansiBrightMagenta": "#B4009E",
        "terminal.ansiBrightRed": "#E74856",
        "terminal.ansiBrightWhite": "#F2F2F2",
        "terminal.ansiBrightYellow": "#F9F1A5",
        "terminal.ansiCyan": "#3A96DD",
        "terminal.ansiGreen": "#13A10E",
        "terminal.ansiMagenta": "#881798",
        "terminal.ansiRed": "#C50F1F",
        "terminal.ansiWhite": "#CCCCCC",
        "terminal.ansiYellow": "#C19C00",
        "terminal.background": "#012456",
        "terminal.foreground": "#CCCCCC",
        "terminalCursor.background": "#FFFFFF",
        "terminalCursor.foreground": "#FFFFFF",

        /* IBM Carbon (Gray 10 Schema) -------------------------------------- */

        "editor.background": "#F4F4F4",
        "editor.foreground": "#161616"
    },

    /* SYNTAX ||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||| */

    "tokenColors": [
        //
        /* RESET (Gray 100) ------------------------------------------------- */

        {
            "scope": [
                "keyword.operator",
                "meta.brace",
                "punctuation",
                "variable.other.object.js",
                "variable.other.object.jsx",
                "variable.other.object.ts",
                "variable.other.object.tsx"
            ],
            "settings": { "foreground": "#161616" }
        },

        /* Yellow 60 -------------------------------------------------------- */

        {
            "scope": [
                "entity.name.class",
                "entity.name.type",
                "entity.name.type.class",
                "entity.other.inherited-class",
                "meta.array.literal.js variable",
                "meta.array.literal.jsx variable",
                "meta.array.literal.ts variable",
                "meta.array.literal.tsx variable",
                "meta.class",
                "support.class"
            ],
            "settings": {
                "foreground": "#8e6a00"
            }
        },

        /* Yellow Hover 60 -------------------------------------------------- */

        {
            "scope": [
                "entity.name.type.interface.ts",
                "entity.name.type.interface.tsx",
                "entity.name.type.alias.ts",
                "entity.name.type.alias.tsx",
                "meta.type.parameters.ts",
                "meta.type.parameters.tsx"
            ],
            "settings": {
                "foreground": "#755800"
            }
        },

        /* Orange 60 -------------------------------------------------------- */

        {
            "scope": [
                "constant",
                "constant.numeric",
                "constant.variable",
                "entity.other.attribute-name",
                "keyword.other.unit",
                "markup.bold",
                "markup.quote",
                "meta.array-binding-pattern-variable.js variable.other.readwrite.js",
                "meta.array-binding-pattern-variable.ts variable.other.readwrite.ts",
                "meta.array-binding-pattern-variable.tsx variable.other.readwrite.tsx",
                "meta.link",
                "support.constant",
                "token.warn-token",
                "variable.other.constant.js",
                "variable.other.constant.jsx",
                "variable.other.constant.ts",
                "variable.other.constant.tsx",
                "variable.other.constant.object.js",
                "variable.other.constant.object.jsx",
                "variable.other.constant.object.ts",
                "variable.other.constant.object.tsx",
                "variable.other.constant.property.js",
                "variable.other.constant.property.jsx",
                "variable.other.constant.property.ts",
                "variable.other.constant.property.tsx"
            ],
            "settings": {
                "foreground": "#ba4e00"
            }
        },

        /* Orange Hover 60 -------------------------------------------------- */

        {
            "scope": [
                /* NOT ASSIGNED */
            ],
            "settings": {
                "foreground": "#9e4200"
            }
        },

        /* Red 60 ----------------------------------------------------------- */

        {
            "scope": [
                "entity.name.operator",
                "entity.name.section.markdown",
                "entity.name.tag",
                "invalid",
                "keyword.control.anchor.regexp",
                "keyword.control.default.js",
                "keyword.control.default.ts",
                "keyword.control.default.tsx",
                "keyword.other.directive.using",
                "keyword.other.operator",
                "keyword.other.using",
                "markup.deleted",
                "markup.heading",
                "meta.definition.variable",
                "meta.export.default.js variable.other.readwrite.js",
                "meta.export.default.ts variable.other.readwrite.ts",
                "meta.object-literal.key.js",
                "meta.object-literal.key.ts",
                "source.css variable",
                "source.ini keyword.other.definition.ini",
                "source.js support.variable",
                "source.json meta.structure.dictionary.json > string.quoted.json",
                "source.ts support.variable",
                "source.tsx support.variable",
                "string.other.link",
                "support.type.object.module.js",
                "support.type.object.module.jsx",
                "support.type.object.module.ts",
                "support.type.object.module.tsx",
                "support.type.property-name",
                "support.type.property-name.json",
                "support.type.vendored.property-name",
                "support.variable.dom.js",
                "support.variable.dom.jsx",
                "support.variable.dom.ts",
                "support.variable.dom.tsx",
                "support.variable.property.dom.js",
                "support.variable.property.dom.jsx",
                "support.variable.property.dom.ts",
                "support.variable.property.dom.tsx",
                "support.variable.property.js",
                "support.variable.property.jsx",
                "support.variable.property.ts",
                "support.variable.property.tsx",
                "variable",
                "variable.other.readwrite.alias.js",
                "variable.other.readwrite.alias.jsx",
                "variable.other.readwrite.alias.ts",
                "variable.other.readwrite.alias.tsx"
            ],
            "settings": {
                "foreground": "#da1e28"
            }
        },

        /* Red Hover 60 ----------------------------------------------------- */

        {
            "scope": [
                "entity.name.selector",
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.id.css",
                "entity.other.attribute-name.parent.less",
                "entity.other.attribute-name.parent-selector.css",
                "entity.other.attribute-name.pseudo-element.css",
                "entity.other.attribute-name.scss",
                "markup.inline.raw",
                "meta.preprocessor.string",
                "source.css entity.other.attribute-name.class",
                "source.css entity.other.attribute-name.pseudo-class",
                "source.css.less entity.other.attribute-name.id"
            ],
            "settings": {
                "foreground": "#b81922"
            }
        },

        /* Magenta 60 ------------------------------------------------------- */

        {
            "scope": [
                "support.other.parenthesis.regexp",
                "token.debug-token",
                "token.error-token",
                "variable.interpolation"
            ],
            "settings": {
                "foreground": "#d02670"
            }
        },

        /* Magenta Hover 60 ------------------------------------------------- */

        {
            "scope": [
                "constant.character.character-class.regexp",
                "constant.character.set.regexp",
                "constant.other.character-class.regexp",
                "constant.other.character-class.set.regexp",
                "constant.regexp"
            ],
            "settings": {
                "foreground": "#b0215f"
            }
        },

        /* Purple 60 -------------------------------------------------------- */

        {
            "scope": [
                "entity.name.namespace",
                "entity.name.operator.custom-literal",
                "entity.name.scope-resolution",
                "entity.other.attribute",
                "keyword",
                "keyword.control",
                "keyword.operator.expression",
                "markup.changed",
                "markup.italic",
                "markup.underline.link.image.markdown",
                "markup.underline.link.markdown",
                "meta.selector",
                "source.powershell variable.other.member",
                "storage",
                "support.constant.handlebars"
            ],
            "settings": {
                "foreground": "#8a3ffc"
            }
        },

        /* Purple Hover 60 -------------------------------------------------- */

        {
            "scope": [
                "entity.name.function.lifecycle.react",
                "support.function.react",
                "support.function.next",
                "entity.name.function.getStaticProps",
                "entity.name.function.getServerSideProps",
                "entity.name.function.getStaticPaths"
            ],
            "settings": {
                "foreground": "#7822fb"
            }
        },

        /* Blue 60 ---------------------------------------------------------- */

        {
            "scope": [
                "constant.character",
                "constant.language",
                "constant.other.option",
                "entity.name.function",
                "entity.name.function.preprocessor",
                "entity.name.section",
                "entity.other.attribute-name.id",
                "keyword.other.special-method",
                "meta.preprocessor",
                "meta.require",
                "source.gfm link entity",
                "storage.modifier",
                "string.other.link.description.markdown",
                "string.other.link.title.markdown",
                "string.quoted.double.handlebars",
                "string.quoted.double.html",
                "string.quoted.double.xml",
                "string.quoted.single.handlebars",
                "string.quoted.single.html",
                "string.quoted.single.xml",
                "string.quoted.single.yaml",
                "string.unquoted.block.yaml",
                "string.unquoted.cdata.xml",
                "string.unquoted.html",
                "string.unquoted.plain.in.yaml",
                "string.unquoted.plain.out.yaml",
                "support.function.any-method",
                "token.info-token",
                "variable.language"
            ],
            "settings": {
                "foreground": "#0f62fe"
            }
        },

        /* Blue Hover 60 ---------------------------------------------------- */

        {
            "scope": [
                "string.template.js",
                "string.template.jsx",
                "string.template.ts",
                "string.template.tsx",
                "meta.template.expression.js",
                "meta.template.expression.jsx",
                "meta.template.expression.ts",
                "meta.template.expression.tsx"
            ],
            "settings": {
                "foreground": "#0050e6"
            }
        },

        /* Cyan 60 ---------------------------------------------------------- */

        {
            "scope": [
                "constant.character.escape",
                "constant.language.import-export-all.js",
                "constant.language.import-export-all.jsx",
                "constant.language.import-export-all.ts",
                "constant.language.import-export-all.tsx",
                "constant.language.json",
                "constant.other.color",
                "constant.other.symbol",
                "markup.link",
                "source.json meta.structure.array.json > constant.language.json",
                "source.json meta.structure.dictionary.json > constant.language.json",
                "string.regexp",
                "support.type",
                "variable.other.constant"
            ],
            "settings": {
                "foreground": "#0072c3"
            }
        },

        /* Cyan Hover 60 ---------------------------------------------------- */

        {
            "scope": [
                "constant.other.color.rgb-value",
                "constant.other.rgb-value",
                "meta.diff.header",
                "meta.object-literal.key",
                "support.constant.color",
                "support.constant.font-name",
                "support.constant.media",
                "support.constant.media-type",
                "support.constant.property-value",
                "support.function.git-rebase",
                "variable.other.enummember"
            ],
            "settings": {
                "foreground": "#005fa3"
            }
        },

        /* Teal 60 ---------------------------------------------------------- */

        {
            "scope": [
                "constant.sha.git-rebase",
                "meta.preprocessor.numeric",
                "meta.type.cast.expr",
                "meta.type.new.expr",
                "source.css property-name",
                "source.css property-value",
                "source.gfm markup",
                "support.constant.dom",
                "support.constant.json",
                "support.constant.math",
                "support.function"
            ],
            "settings": {
                "foreground": "#007d79"
            }
        },

        /* Teal Hover 60 ---------------------------------------------------- */

        {
            "scope": [
                "support.constant.environment",
                "source.prisma keyword.type",
                "source.prisma entity.name.field"
            ],
            "settings": {
                "foreground": "#006b68"
            }
        },

        /* Green 60 --------------------------------------------------------- */

        {
            "scope": [
                "entity.name.type.module.js",
                "entity.name.type.module.ts",
                "entity.name.type.module.jsx",
                "entity.name.type.module.tsx",
                "markup.inline.raw.markdown",
                "markup.inserted",
                "markup.raw",
                "source.json meta.structure.array.json > value.json > string.quoted.json",
                "source.json meta.structure.dictionary.json > value.json > string.quoted.json",
                "string"
            ],
            "settings": {
                "foreground": "#198038"
            }
        },

        /* Green Hover 60 --------------------------------------------------- */

        {
            "scope": [
                "markup.inserted.git",
                "markup.deleted.git",
                "meta.diff.range.git"
            ],
            "settings": {
                "foreground": "#166f31"
            }
        },

        /* Cool Gray 60 ----------------------------------------------------- */

        {
            "scope": [
                /* NOT ASSIGNED */
            ],
            "settings": {
                "foreground": "#697077"
            }
        },

        /* Cool Gray Hover 60 ----------------------------------------------- */

        {
            "scope": [
                /* NOT ASSIGNED */
            ],
            "settings": {
                "foreground": "#585e64"
            }
        },

        /* Gray 60 ---------------------------------------------------------- */

        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": {
                "foreground": "#6f6f6f",
                "fontStyle": "italic"
            }
        },

        /* Gray Hover 60 ---------------------------------------------------- */

        {
            "scope": [
                /* NOT ASSIGNED */
            ],
            "settings": {
                "foreground": "#5e5e5e"
            }
        },

        /* Warm Gray 60 ----------------------------------------------------- */

        {
            "scope": [
                /* NOT ASSIGNED */
            ],
            "settings": {
                "foreground": "#726e6e"
            }
        },

        /* Warm Gray Hover 60 ----------------------------------------------- */

        {
            "scope": [
                /* NOT ASSIGNED */
            ],
            "settings": {
                "foreground": "#605d5d"
            }
        }
    ]
}
