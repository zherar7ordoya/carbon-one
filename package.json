{
    "name": "carbon-one",
    "displayName": "Carbon One",
    "description": "A light theme designed for readability and long-term visual comfort, based on IBM Carbon and inspired by Atom One Light.",
    "version": "3.1.2",
    "publisher": "Gerardo-Tordoya",
    "icon": "icon.png",
    "keywords": [
        "light theme",
        "readability",
        "low eye strain",
        "contrast",
        "clean",
        "minimal",
        "atom one light",
        "carbon",
        "accessible"
    ],
    "engines": {
        "vscode": "^1.80.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/zherar7ordoya/carbon-one"
    },
    "scripts": {
        "package": "vsce package",
        "publish": "vsce publish"
    },
    "categories": [
        "Themes"
    ],
    "contributes": {
        "themes": [
            {
                "label": "Carbon One",
                "uiTheme": "vs",
                "path": "./themes/carbon-one-color-theme.json"
            }
        ]
    },
    "homepage": "https://github.com/zherar7ordoya/carbon-one#readme",
    "devDependencies": {
        "@vscode/vsce": "^3.9.1"
    },
    "packageManager": "pnpm@10.33.0"
}
